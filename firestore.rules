rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function knownWord(wordId) {
      return exists(/databases/$(database)/documents/vocab/$(wordId));
    }

    function validLevels(levels) {
      return levels is list
        && levels.size() > 0
        && levels.size() <= 5
        && levels.hasOnly(["N5", "N4", "N3", "N2", "N1"]);
    }

    function validSettings(data) {
      return data.keys().hasOnly(["levels", "newWordRatio", "sessionSize", "updatedAt"])
        && validLevels(data.levels)
        && data.newWordRatio is int
        && data.newWordRatio >= 0
        && data.newWordRatio <= 100
        && data.sessionSize is int
        && data.sessionSize >= 1
        && data.sessionSize <= 80
        && data.updatedAt == request.time;
    }

    function statsKeys(data) {
      return data.keys().hasOnly([
        "seenCount",
        "correctCount",
        "wrongCount",
        "correctStreak",
        "totalThinkMs",
        "avgThinkMs",
        "lastThinkMs",
        "lastSeenAt",
        "lastResult",
        "updatedAt"
      ]);
    }

    function validStatsShape(data) {
      return statsKeys(data)
        && data.seenCount is int
        && data.correctCount is int
        && data.wrongCount is int
        && data.correctStreak is int
        && data.totalThinkMs is int
        && data.avgThinkMs is int
        && data.lastThinkMs is int
        && data.lastThinkMs >= 250
        && data.lastThinkMs <= 300000
        && data.lastResult in ["known", "unknown"]
        && data.lastSeenAt == request.time
        && data.updatedAt == request.time
        && data.seenCount >= 1
        && data.correctCount >= 0
        && data.wrongCount >= 0
        && data.correctStreak >= 0
        && data.totalThinkMs >= data.lastThinkMs
        && data.avgThinkMs >= 0
        && data.avgThinkMs <= 300000;
    }

    function validStatsCreate(data) {
      return validStatsShape(data)
        && data.seenCount == 1
        && data.totalThinkMs == data.lastThinkMs
        && (
          (data.lastResult == "known"
            && data.correctCount == 1
            && data.wrongCount == 0
            && data.correctStreak == 1)
          ||
          (data.lastResult == "unknown"
            && data.correctCount == 0
            && data.wrongCount == 1
            && data.correctStreak == 0)
        );
    }

    function validStatsUpdate(before, after) {
      return validStatsShape(after)
        && after.seenCount == before.seenCount + 1
        && after.totalThinkMs == before.totalThinkMs + after.lastThinkMs
        && (
          (after.lastResult == "known"
            && after.correctCount == before.correctCount + 1
            && after.wrongCount == before.wrongCount
            && after.correctStreak == before.correctStreak + 1)
          ||
          (after.lastResult == "unknown"
            && after.correctCount == before.correctCount
            && after.wrongCount == before.wrongCount + 1
            && after.correctStreak == 0)
        );
    }

    function validHistoryCreate(data) {
      return data.keys().hasOnly(["wordId", "result", "elapsed", "at"])
        && data.wordId is string
        && knownWord(data.wordId)
        && data.result in ["known", "unknown"]
        && data.elapsed is int
        && data.elapsed >= 250
        && data.elapsed <= 300000
        && data.at == request.time;
    }

    match /vocab/{wordId} {
      allow read: if true;
      allow write: if false;
    }

    match /system/vocabVersion {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(["updatedAt", "localImportSupported"])
        && request.resource.data.updatedAt == request.time
        && request.resource.data.localImportSupported == false;
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["updatedAt"])
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;

      match /settings/current {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && validSettings(request.resource.data);
        allow delete: if false;
      }

      match /wordStats/{wordId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && knownWord(wordId)
          && validStatsCreate(request.resource.data);
        allow update: if isOwner(uid)
          && knownWord(wordId)
          && validStatsUpdate(resource.data, request.resource.data);
        allow delete: if isOwner(uid);
      }

      match /history/{eventId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && validHistoryCreate(request.resource.data);
        allow update: if false;
        allow delete: if isOwner(uid);
      }
    }
  }
}
